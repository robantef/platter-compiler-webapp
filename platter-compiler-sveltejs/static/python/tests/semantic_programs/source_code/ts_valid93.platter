prepare piece of isperfect(piece of n){
    piece of i = 1;
    piece of sum = 0;

    check(n <= 1){
        serve 0;
    }

    repeat(i < n){
        check(n % i == 0){
            sum = sum + i;
        }
        i = i + 1;
    }

    check(sum == n){
        serve 1;
    }

    serve 0;
}

start(){
    piece of x = 1;
    piece of y = 100;
    piece of i = 0;
    piece of idx = 0;
    piece of total = 0;
    piece[] of perfects = [];

    i = x;
    repeat(i <= y){
        check(isperfect(i) == 1){
            perfects = append(perfects, i);
        }
        i = i + 1;
    }

    total = size(perfects);
    idx = 0;
    repeat(idx < total){
        bill(tochars(perfects[idx]));
        idx = idx + 1;
    }
}