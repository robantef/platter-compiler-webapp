piece[] of x =[1,2];
sip[] of y = [1.0,2.0];
chars[] of z = ["Hello","World"];
start(){
	piece of a = size(x) / (size(y)-size(z)); # causes an error, cannot divide by 0
    chars[] of j = ["another", "one"];
    bill(tochars(a)); 

	z = remove(z,0);
    j = ["one only"];
	bill(z[1] + j[1]); # causes an error, accessing out of bounds, array size after remove and reassignment = 1 
}