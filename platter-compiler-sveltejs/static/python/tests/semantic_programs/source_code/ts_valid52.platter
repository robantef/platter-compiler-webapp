table of Data = [
    piece[] of x;
    chars[] of y;
    sip[] of z;
    flag[] of f;
];

start() {
    Data of x = [
        x = [1, 2];
        y = ["Raphael", "James"];
        z = [1.1, 2.2];
        f = [up, down];
    ];
    x:x = [1, 2];
    x:y = ["Raphael", "James"];
    x:z = [1.1, 2.2];
    x:f = [up, down];
}